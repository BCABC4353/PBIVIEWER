{
  "expo": {
    "name": "MEDIC Workflows",
    "slug": "medic-workflows",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "medicworkflows",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B0D",
    "primaryColor": "#E8A33D",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bcabc.medicworkflows",
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#0B0B0D"
      }
    },
    "android": {
      "package": "com.bcabc.medicworkflows",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0D",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#0B0B0D"
      },
      "predictiveBackGestureEnabled": false
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#0B0B0D"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#0B0B0D"
    }
  }
}
