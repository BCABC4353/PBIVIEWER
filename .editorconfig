# EditorConfig (editorconfig.org) — keeps editors/agents from introducing
# tab/space or line-ending drift the repo has so far avoided only by luck.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.ps1]
end_of_line = crlf

[*.md]
# Trailing double-space is meaningful in Markdown.
trim_trailing_whitespace = false
